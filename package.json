{
  "name": "@selectwin/sdk",
  "version": "0.1.0",
  "description": "Official Selectwin Node.js / TypeScript SDK — payments (card, PIX, boleto), subscriptions, webhooks.",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=18" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "sync:core": "node scripts/sync-core.mjs && node scripts/gen-namespaces.mjs && node scripts/gen-webhook-events.mjs",
    "gen:namespaces": "node scripts/gen-namespaces.mjs",
    "gen:webhook-events": "node scripts/gen-webhook-events.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "repository": { "type": "git", "url": "https://github.com/selectwin/sdk-nodejs.git" },
  "homepage": "https://docs.selectwin.io",
  "keywords": ["selectwin", "payments", "pix", "boleto", "subscriptions", "webhooks", "api", "sdk"]
}
